{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @agency-terminal/controls build",
  "outputDirectory": "apps/controls/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/:path((?:.*))",
      "destination": "/api/index?path=:path"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
