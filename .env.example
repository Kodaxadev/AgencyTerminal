# Agency Terminal Environment Variables
# Copy to .env and fill in values.

# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_ENABLE_GUILD_MEMBERS_INTENT=false

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agency_terminal

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Agency Channels
AGENCY_ADMIN_CHANNEL_ID=
AGENCY_AUDIT_CHANNEL_ID=
AGENCY_OPS_QUEUE_CHANNEL_ID=
AGENCY_ALLOW_OPS_QUEUE_SETUP=false

# Environment
NODE_ENV=development
